{
  "name": "pi-app-frontend",
  "version": "1.0.0",
  "description": "Frontend React Native + Expo for workshop management system",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start --clean",
    "start:localhost": "expo start --localhost",
    "start:lan": "expo start --lan",
    "start:wsl": "bash scripts/start-wsl.sh",
    "start:windows": "call scripts/start-windows.bat",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "prebuild": "expo prebuild --clean",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios"
  },
  "dependencies": {
    "expo": "~54.0.0",
    "react": "18.3.1",
    "react-native": "0.76.0",
    "react-native-screens": "~4.1.0",
    "react-native-safe-area-context": "4.12.0",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/stack": "^6.4.1",
    "@react-navigation/drawer": "^6.7.2",
    "axios": "^1.7.7",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-native": "^0.76.0",
    "typescript": "^5.6.3",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.36.1",
    "eslint-plugin-react-native": "^4.1.0",
    "prettier": "^3.3.3",
    "expo-cli": "~14.0.0"
  }
}
