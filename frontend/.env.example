# Example environment file for local development
# Copie este arquivo para .env.local e configure conforme necessário

# API Backend URL
# Para Windows: use localhost ou seu IP local
# Para WSL: use o IP do host Windows (descubra com: hostname -I no WSL)
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Ou para conexão via IP (para WSL):
# EXPO_PUBLIC_API_URL=http://192.168.x.x:3000/api

# Ambiente
EXPO_PUBLIC_ENV=development

# Timeout padrão para requisições (em ms)
EXPO_PUBLIC_API_TIMEOUT=30000
